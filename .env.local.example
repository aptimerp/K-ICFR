# Smart-ICM 환경변수 템플릿
# 실제 값은 홍세민 PM께 수령 후 .env.local 파일로 복사
# .env.local은 절대 Git 커밋 금지 (.gitignore 보호됨)

# Supabase (클라이언트 공개 가능)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase 서비스 롤 키 (서버 측 전용, 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 금강 ERP API (SAC 이영호 차장 수령 후 설정 — Phase 8)
KUMKANG_API_URL=https://erp.kumkang.com/api
KUMKANG_API_KEY=
